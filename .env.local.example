# Copy this file to .env.local and fill in your Supabase project values
# (Project Settings -> API in the Supabase dashboard)

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key is only used server-side (API routes) for write operations
# that should bypass row-level security, e.g. marking items as exported.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
