# Copy this file to .env.local and fill in your Supabase project values
# (Project Settings -> API in the Supabase dashboard)
# Newer Supabase dashboards label these "Publishable key" / "Secret key"
# instead of "anon key" / "service_role key" — same values, new names.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# Service role / secret key is only used server-side (API routes) for write
# operations that should bypass row-level security, e.g. marking items as
# exported.
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# --- Google Sheet auto-sync (POST /api/sync-sheet) ---
# See README.md "Đồng bộ tự động từ Google Sheet" for how to get these.
# Requires the Sheet to be shared as "Anyone with the link: Viewer".
GOOGLE_API_KEY=your-google-api-key
# The id segment of the Sheet's URL, between /d/ and /edit.
GOOGLE_SHEET_ID=your-sheet-id
# Any random string — also set as the SYNC_SECRET GitHub repo secret, and
# sent as "Authorization: Bearer <this>" by the scheduled GitHub Action.
SYNC_SECRET=make-up-a-random-string
